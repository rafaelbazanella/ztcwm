{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "declaration": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": ".",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules", "dist", "./**/*.test.ts"]
}
