# ──────────────────────────────────────────
# ZTCWM — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env (dev) or render it into /etc/ztcwm/ztcwm.env (prod).
#   cp .env.example .env

# ── Server ────────────────────────────────
# Port the Fastify backend listens on.
PORT=3000

# Node environment. In 'production' the backend serves the built SPA from
# server/dist + skips the Vite dev proxy. Anything else is treated as dev.
NODE_ENV=development

# ── Security ──────────────────────────────
# SESSION_SECRET is the SINGLE secret the backend needs.
# It signs session cookies AND is hashed (sha256) to derive the AES-256-GCM
# key that encrypts the stored ZeroTier auth token in the zt_config table.
# In production: generate with `openssl rand -hex 32` and store in
# /etc/ztcwm/ztcwm.env (mode 0600, owner ztcwm:ztcwm). NEVER commit a real value.
SESSION_SECRET=change-me-to-a-random-secret

# Set to "true" when the app is served behind HTTPS (sets Secure flag on the
# session cookie). REQUIRED in production.
# COOKIE_SECURE=true

# ── Database ──────────────────────────────
# Path to the SQLite database file. Defaults to ./data/ztcwm.db relative to
# the backend's working directory. Set to /var/lib/ztcwm/ztcwm.db in production.
# ZTCWM_DB_PATH=./data/ztcwm.db

# ── ZeroTier (optional pre-seed) ──────────
# If both are set, the setup wizard skips the ZT-token step and uses these
# values verbatim. Useful for Docker/automated deploys.
# ZTCWM_ZT_URL=http://localhost:9993
# ZTCWM_ZT_TOKEN=24-digits-token
